# ─── Fill this in ────────────────────────────────────────────────
# Trakt API app Client ID — create one at https://trakt.tv/oauth/applications
# (Redirect URI: urn:ietf:wg:oauth:2.0:oob — only the Client ID is used)
TRAKT_CLIENT_ID=

# ─── Self-contained stack (defaults work out of the box) ─────────
# For a real deployment, change these. If you change PGRST_JWT_SECRET you
# MUST regenerate SUPABASE_SERVICE_KEY:  node scripts/gen-service-jwt.mjs "<new-secret>"
POSTGRES_PASSWORD=postgres
PGRST_JWT_SECRET=wetrakr_relay_demo_secret_please_change_0001
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIn0.IjKPAW11GUShxuZpym1AVAjBY6mSYYvlkFb2b1Ift4w

# ─── Reverse proxy / domain ──────────────────────────────────────
# Your public URL behind the reverse proxy (Pangolin/newt, nginx, Caddy, …).
# Used to build the manage link. Leave blank to auto-detect from the browser.
#   example: https://track.example.com
APP_URL=

# Host port for the web UI — your reverse proxy (newt) forwards to this port.
WEB_PORT=8088

# ─── Optional ────────────────────────────────────────────────────
# WeTrakr API base (unofficial, from the Kodi add-on)
WETRAKR_API_URL=https://api.wetrakr.com
